[{"title_en": "Yellow Color (Turmeric Tincture) - Second Maceration", "title_it": "Colore giallo (di curcuma)", "section_en": "Coloring agents for liqueurs", "method": "maceration", "ingredients": [{"name_en": "Water", "name_it": "Acqua", "qty": 200, "unit": "g", "unit_implicit": false, "variants": null, "note": ""}, {"name_en": "Alcohol 95°", "name_it": "Alcool di 95°", "qty": 400, "unit": "g", "unit_implicit": false, "variants": null, "note": ""}], "steps_en": ["Add this mixture to the residue after decanting the previously obtained liquid.", "Shake vigorously and allow to macerate for another 4 days.", "Decant the liquid and combine it with the previously obtained liquid.", "Filter through paper."], "notes_en": "The resulting yellow tint is close to that of saffron but turns red with calcium salts, which can affect coloring when using hard water. Turmeric added directly to weak alcohol liqueurs (45-50°) gives poor coloration; its tincture is preferable. This recipe appears to continue from an unshown earlier step involving turmeric maceration.", "confidence": 0.55, "page": 299, "source": "prose-rescue"}, {"title_en": "Catechu Color", "title_it": "Colore di cattù", "section_en": "Coloring agents for liqueurs", "method": "maceration", "ingredients": [{"name_en": "Catechu earth, coarsely ground", "name_it": "Terra cattù grossolanamente contusa", "qty": 300, "unit": "g", "unit_implicit": false, "variants": null, "note": ""}, {"name_en": "Alcohol 90°", "name_it": "Alcool di 90°", "qty": 800, "unit": "g", "unit_implicit": false, "variants": null, "note": ""}, {"name_en": "Distilled water", "name_it": "Acqua distillata", "qty": 200, "unit": "g", "unit_implicit": false, "variants": null, "note": ""}], "steps_en": ["Proceed as for the yellow color of calendula (see p. 287)."], "notes_en": "", "confidence": 0.9, "page": 299, "source": "prose-rescue"}, {"title_en": "Color for Curaçao", "title_it": "Colore per curaçao", "section_en": "Coloring agents for liqueurs", "method": "maceration", "ingredients": [{"name_en": "Fernambuco wood", "name_it": "Legno di Fernambuco", "qty": 100, "unit": "g", "unit_implicit": false, "variants": null, "note": ""}, {"name_en": "Brazil wood", "name_it": "Legno del Brasilo", "qty": 100, "unit": "g", "unit_implicit": false, "variants": null, "note": ""}, {"name_en": "Cream of tartar", "name_it": "Cremortartaro", "qty": 4, "unit": "g", "unit_implicit": false, "variants": null, "note": ""}, {"name_en": "Alcohol 90°", "name_it": "Alcool di 90°", "qty": 0.5, "unit": "l", "unit_implicit": false, "variants": null, "note": ""}], "steps_en": ["Arrange the woods in glazed earthenware vessels in distinct layers.", "Dust them with cream of tartar.", "Pour the alcohol over them and macerate for about 8 days.", "Fully exhaust the residue with a fresh dose of alcohol."], "notes_en": "", "confidence": 0.9, "page": 299, "source": "prose-rescue"}]